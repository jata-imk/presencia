# Copia a .env y ajusta. NUNCA commitees .env.
POSTGRES_USER=presencia
POSTGRES_PASSWORD=cambia-esto
POSTGRES_DB=presencia
POSTGRES_PORT=5432

# Conexión de migraciones — rol owner (apunta al compose local o al túnel SSH del VPS)
DATABASE_URL=postgres://presencia:cambia-esto@localhost:5432/presencia

# Conexión del runtime de la API — rol presencia_app, sujeto a RLS (ADR-003).
# El password NO viene en las migraciones; asígnalo una vez por entorno:
#   ALTER ROLE presencia_app WITH PASSWORD 'cambia-esto-tambien';
APP_DATABASE_URL=postgres://presencia_app:cambia-esto-tambien@localhost:5432/presencia

# Better Auth (ADR-007). Genera el secret con: openssl rand -base64 32
BETTER_AUTH_SECRET=cambia-esto-32-chars-minimo-aleatorio
BETTER_AUTH_URL=http://localhost:3000
WEB_URL=http://localhost:5173

# IA multi-proveedor (ADR-004). El modelo activo se elige con AI_MODEL en
# formato proveedor:modelo — cambiarlo requiere reiniciar el proceso.
# Solo la key del proveedor de AI_MODEL es obligatoria; las demás son
# opcionales (sin key, ese proveedor no se registra).
AI_MODEL=google:gemini-3.5-flash
# Gemini — key gratis en https://aistudio.google.com
GOOGLE_GENERATIVE_AI_API_KEY=tu-api-key
# OpenAI (opcional) — https://platform.openai.com/api-keys
# OPENAI_API_KEY=tu-api-key
# MiniMax (opcional, API compatible con OpenAI) — https://api.minimax.io
# MINIMAX_API_KEY=tu-api-key
# MINIMAX_BASE_URL=https://api.minimax.io/v1

# Correo transaccional — Zoho ZeptoMail (verificación de email)
ZEPTOMAIL_TOKEN=tu-send-mail-token
MAIL_FROM=no-reply@tu-dominio.mx
