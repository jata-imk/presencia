{
  "name": "@presencia/api",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src drizzle.config.ts",
    "dev": "tsx watch --env-file=../../.env src/main.ts",
    "test": "vitest run",
    "suite:cultural": "tsx --env-file=../../.env scripts/cultural-suite/run.ts",
    "start": "node dist/main.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^4.0.16",
    "@ai-sdk/deepseek": "^3.0.12",
    "@ai-sdk/google": "^4.0.18",
    "@ai-sdk/openai": "^3.0.86",
    "@ai-sdk/openai-compatible": "^2.0.62",
    "@nestjs/common": "^11.1.0",
    "@nestjs/core": "^11.1.0",
    "@nestjs/platform-express": "^11.1.0",
    "@presencia/shared": "workspace:*",
    "ai": "7.0.31",
    "better-auth": "1.6.23",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "pg": "^8.16.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.1",
    "@types/node": "^22.15.0",
    "@types/pg": "^8.15.0",
    "drizzle-kit": "^0.31.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^4.1.10"
  }
}
